# GitHub OAuth App credentials (https://github.com/settings/developers)
GITHUB_CLIENT_ID=Ov23li3hOIGzfokgTMUT
GITHUB_CLIENT_SECRET=4e101ad1841152b45c8e9a20b8850bd4cd043c7a

# Random string for signing session cookies (use: openssl rand -base64 32)
SESSION_SECRET= mysecretkey32

# Frontend URL (where users are redirected after login)
CLIENT_URL=http://localhost:3000

# Backend port
PORT=4000

# Optional: override OAuth callback URL (defaults to CLIENT_URL/api/auth/github/callback)
# GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# Set to "production" in production for secure cookies
NODE_ENV=development

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
