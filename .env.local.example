# Backend URL used by Next.js to proxy /api/* requests (development)
BACKEND_URL=http://localhost:4000

# Public API base URL for the frontend (keep as /api when using the proxy)
NEXT_PUBLIC_API_URL=/api

# OAuth login URL — must point directly at the Express server (not the Next.js proxy)
NEXT_PUBLIC_OAUTH_URL=http://localhost:4000/api
